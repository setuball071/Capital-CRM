# =============================================================================
# Capital CRM — variáveis de ambiente
# Copie para .env (local) ou cadastre no painel do host (Cloudfy → App → Env).
# =============================================================================

# --- Banco de dados (Supabase Postgres do Cloudfy) ---------------------------
# Connection string completa do Postgres. Ex.:
#   postgresql://postgres:SENHA@HOST:5432/postgres
DATABASE_URL=

# SSL do banco:
#   DATABASE_SSL=disable   -> sem SSL (use quando o app e o Postgres estão na
#                             mesma rede interna do Cloudfy)
#   (vazio)                -> SSL ligado SEM validar o certificado (padrão,
#                             aceita o cert próprio do Supabase self-hosted)
DATABASE_SSL=
# Só ligue se tiver um certificado de CA confiável e quiser validação estrita:
DATABASE_SSL_REJECT_UNAUTHORIZED=

# --- Sessão / segurança ------------------------------------------------------
SESSION_SECRET=
# Origens permitidas no CORS, separadas por vírgula (ex.: https://sistemacapital.com.br)
ALLOWED_ORIGINS=
# Em produção use "production". NÃO defina isto no passo de BUILD do host,
# senão o npm install pula as devDependencies (vite/esbuild) e o build quebra.
NODE_ENV=production
# Porta do servidor. O Cloudfy injeta a porta automaticamente; default 5000.
PORT=5000

# --- Supabase Storage (anexos das propostas) ---------------------------------
# Sem estas variáveis, os anexos caem no disco local (fallback do Replit).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=anexos

# --- OpenAI (OCR / extração de documentos) -----------------------------------
# Chave própria da OpenAI (fora do Replit). baseURL é opcional (padrão: OpenAI).
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Google AI (geração de imagens / criativos) ------------------------------
GOOGLE_AI_API_KEY=

# --- Integração LEMIT --------------------------------------------------------
LEMIT_WORKER_KEY=

# --- E-mail (SMTP) -----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# --- Integração WhatsApp (CapitalGo) -----------------------------------------
WHATSAPP_WEBHOOK_SECRET=
CRM_INTEGRATION_SECRET=
# Variável de BUILD do frontend (precisa existir no momento do build):
VITE_WHATSAPP_PLATFORM_URL=
